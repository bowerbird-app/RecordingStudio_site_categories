<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <% if recording_studio_site_categories_flatpack_component_available?(
    "FlatPack::PageTitle::Component",
    "FlatPack::Card::Component",
    "FlatPack::Table::Component"
  ) %>
    <%= render FlatPack::PageTitle::Component.new(
      title: "Site categories",
      subtitle: "Category groups registered at boot for the current host app.",
      variant: :h1
    ) %>

    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.body do %>
        <%= render FlatPack::Table::Component.new(data: @groups, class: "text-sm") do |table| %>
          <% table.column(title: "Key", html: ->(group) { group.key.to_s }) %>
          <% table.column(title: "Label", html: ->(group) { group.label }) %>
          <% table.column(title: "Items", html: ->(group) { group.items.join(", ") }) %>
        <% end %>
      <% end %>
    <% end %>
  <% else %>
    <div class="space-y-2">
      <h1 class="text-2xl font-semibold">Site categories</h1>
      <p class="text-sm text-slate-600">Category groups registered at boot for the current host app.</p>
    </div>

    <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white">
      <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
        <thead class="bg-slate-50">
          <tr>
            <th scope="col" class="px-4 py-3 font-medium text-slate-900">Key</th>
            <th scope="col" class="px-4 py-3 font-medium text-slate-900">Label</th>
            <th scope="col" class="px-4 py-3 font-medium text-slate-900">Items</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% @groups.each do |group| %>
            <tr>
              <td class="px-4 py-3 align-top"><%= group.key %></td>
              <td class="px-4 py-3 align-top"><%= group.label %></td>
              <td class="px-4 py-3 align-top"><%= group.items.join(", ") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
