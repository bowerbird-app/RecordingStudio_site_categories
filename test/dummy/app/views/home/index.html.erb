<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Site categories demo",
    subtitle: "This dummy app demonstrates boot-time category registration for RecordingStudio pages.",
    variant: :h1
  ) %>

  <div class="grid gap-6 lg:grid-cols-2">
    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "What this gem does",
          subtitle: "A small registry other gems and host apps can extend during boot.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <ul class="space-y-3 text-sm leading-6">
          <li>Registers named category groups with a label and allowed values.</li>
          <li>Raises a boot error immediately when a duplicate key is registered.</li>
          <li>Provides a concern and FlatPack helper for category-backed model forms.</li>
          <li>Ships without any database tables of its own.</li>
        </ul>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "Demo paths",
          subtitle: "Use the sidebar or jump directly into the two core example screens.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <div class="flex flex-wrap gap-3">
          <%= link_to recording_studio_site_categories.root_path, class: "inline-flex" do %>
            <%= render FlatPack::Button::Component.new(text: "View categories", style: :primary) %>
          <% end %>

          <%= link_to pages_path, class: "inline-flex" do %>
            <%= render FlatPack::Button::Component.new(text: "Manage pages", style: :secondary) %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
