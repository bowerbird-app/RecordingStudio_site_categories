<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Recordings tree",
    subtitle: "Active dummy-app recordings shown as a nested parent/child outline.",
    variant: :h1
  ) %>

  <% if @recording_tree.any? %>
    <%= render FlatPack::Tree::Component.new(compact: true) do |tree| %>
      <% @recording_tree.each do |node| %>
        <%= render partial: "recording_tree_node", locals: { parent_builder: tree, node: node } %>
      <% end %>
    <% end %>
  <% else %>
    <p class="text-sm text-(--surface-muted-content-color)">No active recordings found.</p>
  <% end %>
</div>
