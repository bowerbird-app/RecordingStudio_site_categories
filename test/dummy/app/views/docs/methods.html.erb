<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Methods",
    subtitle: "Document the public methods your addon exposes.",
    variant: :h1
  ) %>

  <%= render FlatPack::SectionTitle::Component.new(
    title: "Example method",
    subtitle: "recordingstudio_addon.example_method",
  ) %>

  <%= render FlatPack::CodeBlock::Component.new(
    language: :ruby,
    code: <<~'CODE'
      # Explain what this method does before the example.
      result = RecordingstudioAddon.example_method(
        # Replace with the real arguments this method accepts.
        input: "demo value"
      )

      # Show what the method returns or what side effect it creates.
      puts result
    CODE
  ) %>

  <p class="text-sm text-(--body-muted-content-color)">
    Provide one section title and codeblock for each method
  </p>
</div>
