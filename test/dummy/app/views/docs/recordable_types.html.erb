<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Recordable types",
    subtitle: "The list below comes from RecordingStudio.recordable_declarations and v3 parent/root introspection.",
    variant: :h1
  ) %>

  <% if @recordable_types.any? %>
    <%= render FlatPack::List::Component.new(divider: true) do %>
      <% @recordable_types.each do |recordable_type| %>
        <%= render FlatPack::List::Item.new(icon: :queue_list) do %>
          <div class="flex flex-col gap-1">
            <span><%= recordable_type.fetch(:label) %></span>
            <span class="text-sm text-(--surface-muted-content-color)">
              <%= recordable_type.fetch(:root) ? "Root recordable" : "Child recordable" %> •
              Allowed parents:
              <%= recordable_type.fetch(:allowed_parent_types).presence&.join(", ") || "none" %> •
              <%= pluralize(recordable_type.fetch(:recordings_count), "recording") %> point to this type •
              <%= pluralize(recordable_type.fetch(:recordables_count), "recordable") %> in the database
            </span>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% else %>
    <p class="text-sm text-(--surface-muted-content-color)">No recordable types are configured.</p>
  <% end %>
</div>