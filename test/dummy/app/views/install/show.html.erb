<div class="mx-auto flex w-full max-w-4xl flex-col gap-8">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Installation",
    subtitle: "How to add recording_studio_site_categories to your Rails app.",
    variant: :h1
  ) %>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "1. Add the gem",
      subtitle: "Add to your Gemfile and install dependencies.",
      variant: :h2
    ) %>

    <%= render FlatPack::CodeBlock::Component.new(
      snippets: [
        { label: "Gemfile", language: "ruby", code: '# Gemfile\ngem "recording_studio_site_categories"' },
        { label: "Terminal", language: "shell", code: "bundle install" }
      ]
    ) %>
  </section>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "2. Run the install generator",
      subtitle: "Creates the initializer with a sample group registration.",
      variant: :h2
    ) %>

    <%= render FlatPack::CodeBlock::Component.new(
      code: "bin/rails generate recording_studio_site_categories:install",
      language: "shell"
    ) %>

    <p class="mt-3 text-sm text-slate-600">
      This creates <code class="rounded bg-slate-100 px-1 py-0.5 text-xs">config/initializers/recording_studio_site_categories.rb</code>
      with a sample <code>:colour</code> group.
    </p>
  </section>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "3. Mount the engine (optional)",
      subtitle: "Add a route to browse registered categories.",
      variant: :h2
    ) %>

    <%= render FlatPack::CodeBlock::Component.new(
      code: "# config/routes.rb\nmount RecordingStudioSiteCategories::Engine, at: \"/site_categories\"",
      language: "ruby"
    ) %>

    <p class="mt-3 text-sm text-slate-600">
      Visit <code class="rounded bg-slate-100 px-1 py-0.5 text-xs">/site_categories</code> to see all registered groups.
    </p>
  </section>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "4. Use in a model",
      subtitle: "Validate single and multiple attributes against registered groups.",
      variant: :h2
    ) %>

    <%= render FlatPack::CodeBlock::Component.new(
      snippets: [
        {
          label: "Model",
          language: "ruby",
          code: "# app/models/page.rb\nclass Page < ApplicationRecord\n  include RecordingStudioSiteCategories::HasCategory.for(:colour, attribute: :site_colour)\n  include RecordingStudioSiteCategories::HasCategory.for(:publication_type, attribute: :site_publications, multiple: true)\nend"
        },
        {
          label: "Migration",
          language: "ruby",
          code: "add_column :pages, :site_colour, :string\nadd_column :pages, :site_publications, :text, array: true, default: []"
        }
      ]
    ) %>
  </section>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "5. Use in a view",
      subtitle: "Render a FlatPack select with the category helper.",
      variant: :h2
    ) %>

    <%= render FlatPack::CodeBlock::Component.new(code: "# ERB usage\n#{@erb_usage_code}") %>
  </section>
</div>