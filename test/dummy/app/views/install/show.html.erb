<div class="mx-auto flex w-full max-w-4xl flex-col gap-8">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Installation",
    subtitle: "How to add recording_studio_site_categories to your Rails app.",
    variant: :h1
  ) %>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "1. Add the gem",
      subtitle: "Add to your Gemfile and install dependencies.",
      variant: :h2
    ) %>

    <pre class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm"><code><span class="text-slate-400"># Gemfile</span>
gem "recording_studio_site_categories"</code></pre>

    <pre class="mt-3 rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm"><code>bundle install</code></pre>
  </section>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "2. Run the install generator",
      subtitle: "Creates the initializer with a sample group registration.",
      variant: :h2
    ) %>

    <pre class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm"><code>bin/rails generate recording_studio_site_categories:install</code></pre>

    <p class="mt-3 text-sm text-slate-600">
      This creates <code class="rounded bg-slate-100 px-1 py-0.5 text-xs">config/initializers/recording_studio_site_categories.rb</code>
      with a sample <code>:colour</code> group.
    </p>
  </section>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "3. Mount the engine (optional)",
      subtitle: "Add a route to browse registered categories.",
      variant: :h2
    ) %>

    <pre class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm"><code><span class="text-slate-400"># config/routes.rb</span>
mount RecordingStudioSiteCategories::Engine, at: "/site_categories"</code></pre>

    <p class="mt-3 text-sm text-slate-600">
      Visit <code class="rounded bg-slate-100 px-1 py-0.5 text-xs">/site_categories</code> to see all registered groups.
    </p>
  </section>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "4. Use in a model",
      subtitle: "Validate an attribute against a registered group.",
      variant: :h2
    ) %>

    <pre class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm"><code><span class="text-slate-400"># app/models/page.rb</span>
class Page &lt; ApplicationRecord
  include RecordingStudioSiteCategories::HasCategory.for(:colour, attribute: :site_colour)
end</code></pre>

    <p class="mt-3 text-sm text-slate-600">
      Also add the column via migration: <code class="rounded bg-slate-100 px-1 py-0.5 text-xs">add_column :pages, :site_colour, :string</code>
    </p>
  </section>

  <section>
    <%= render FlatPack::PageTitle::Component.new(
      title: "5. Use in a view",
      subtitle: "Render a FlatPack select with the category helper.",
      variant: :h2
    ) %>

    <pre class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm"><code><span class="text-slate-400">&lt;%# app/views/pages/_form.html.erb %&gt;</span>
&lt;%= recording_studio_site_category_select(form, :colour, attribute_name: :site_colour) %&gt;</code></pre>
  </section>
</div>