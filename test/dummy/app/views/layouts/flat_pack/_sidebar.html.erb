<%= render FlatPack::Sidebar::Component.new(side: sidebar_side) do |sidebar| %>
  <% sidebar.header do %>
    <%= render FlatPack::Sidebar::Header::Component.new(
      brand_abbr: "SC",
      title: "Site Categories",
      subtitle: "Recording Studio"
    ) %>
  <% end %>

  <% sidebar.items do %>
    <nav class="py-4 space-y-1" aria-label="Main navigation">
      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Categories",
        href: recording_studio_site_categories.root_path,
        icon: :queue_list
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Pages",
        href: main_app.pages_path,
        icon: :document_text
      ) %>

      <%= render FlatPack::Sidebar::SectionTitle::Component.new(label: "Helpers") %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Installation",
        href: main_app.install_path,
        icon: :arrow_down_tray
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Configuration",
        href: main_app.config_path,
        icon: :cog_6_tooth
      ) %>

        <%= render FlatPack::Sidebar::Item::Component.new(
          label: "Helpers",
        href: main_app.helpers_path,
        icon: :code_bracket
      ) %>
    </nav>
  <% end %>

  <% sidebar.footer do %>
    <%= render FlatPack::Sidebar::Footer::Component.new(class: "text-sm text-[var(--surface-muted-content-color)]") do %>
      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Sign out",
        href: main_app.destroy_user_session_path,
        icon: :lock,
        class: "mx-0",
        data: { turbo_method: :delete }
      ) %>
    <% end %>
  <% end %>
<% end %>
